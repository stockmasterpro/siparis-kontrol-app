/**
 * Centralized sync logic for marketplace orders.
 * Fetches new orders, updates statuses, and reconciles stock.
 * 
 * @param db Current database state
 * @returns Updated products and orders, and counts of new items
 */
export const syncMarketplaceOrders = async (
  db: Database,
  isManual = false
): Promise<{
  updatedProducts: Product[],
  updatedOrders: Order[],
  newOrdersAddedCount: number,
  barcodesToSync: { [key: string]: number }
}> => {
  if (db.apiConfigs.length === 0) {
    return {
      updatedProducts: db.products,
      updatedOrders: db.orders,
      newOrdersAddedCount: 0,
      barcodesToSync: {}
    };
  }

  let newOrdersAddedCount = 0;
  let currentDbProducts = [...db.products];
  let currentDbOrders = [...db.orders];
  const barcodesToSync: { [key: string]: number } = {};

  for (const config of db.apiConfigs) {
    let content: any[] = [];

    if (config.mode === 'TEST') {
      // Mock order for testing
      if (isManual || Math.random() > 0.7) {
        let mockVariant = { barcode: 'TEST-BARCODE', color: 'X', size: 'L' };
        let mockProductName = "Test Ürünü";
        let mockPrice = 100;

        if (currentDbProducts.length > 0) {
          const randomProduct = currentDbProducts[Math.floor(Math.random() * currentDbProducts.length)];
          const randomVariant = randomProduct.variants.find(v => v.barcode && v.barcode.length > 0) || randomProduct.variants[0];
          if (randomVariant) {
            mockVariant = randomVariant;
            mockProductName = randomProduct.name;
            mockPrice = randomProduct.price;
          }
        }

        content = [{
          orderNumber: `TEST-${Math.floor(Math.random() * 1000000)}`,
          customerFirstName: "Test",
          customerLastName: "Müşteri",
          cargoTrackingNumber: `${Math.floor(Math.random() * 10000000)}`,
          orderDate: Date.now(),
          status: 'Created',
          lines: [{
            orderItemId: Math.random().toString(36).substr(2, 9),
            barcode: mockVariant.barcode,
            productName: mockProductName,
            merchantSku: `${mockVariant.color}-${mockVariant.size}`,
            quantity: 1,
            price: mockPrice
          }]
        }];
      }
    } else {
      try {
        const startDate = new Date();
        startDate.setDate(startDate.getDate() - (db.settings.orderFetchDays || 2));
        const startDateParams = startDate.getTime();

        let page = 0;
        const size = 100;

        while (true) {
          const pageOrders = await fetchOrdersFromTrendyol(config, {
            startDate: startDateParams,
            page: page,
            size: size
          });

          if (pageOrders.length === 0) break;
          content = content.concat(pageOrders);
          if (pageOrders.length < size) break;
          page++;
        }
      } catch (error) {
        console.error(`[SYNC-ERROR] ${config.storeName} |`, error);
      }
    }

    for (const apiOrder of content) {
      // 3 Saatlik zaman kayması düzeltmesi (Trendyol API zaman zaman UTC yerine TRT timestamp gönderiyor, browser bunu UTC sayıp +3 ekliyor)
      // Kullanıcının "3 saat ilerde" şikayeti üzerine 3 saat (180 dk) geri çekiyoruz.
      const apiOrderDate = apiOrder.orderDate || apiOrder.createdDate || Date.now();
      const orderDate = new Date(apiOrderDate - (3 * 60 * 60 * 1000));

      const cutoffDate = new Date();
      cutoffDate.setDate(cutoffDate.getDate() - (db.settings.orderFetchDays || 2));

      if (orderDate < cutoffDate) continue;

      let mappedStatus = OrderStatus.NEW;
      const status = (apiOrder.status || '').toString().toLowerCase().trim();

      if (status === 'shipped' || status === 'shipping') mappedStatus = OrderStatus.SHIPPING;
      else if (status === 'delivered' || status === 'completed') mappedStatus = OrderStatus.DELIVERED;
      else if (status === 'cancelled' || status === 'canceled') mappedStatus = OrderStatus.CANCELLED;
      else if (status === 'created' || status === 'new' || status === 'pending') mappedStatus = OrderStatus.NEW;
      else if (status === 'picking' || status === 'processing' || status === 'approved') mappedStatus = OrderStatus.PROCESSING;

      const existingOrderIndex = currentDbOrders.findIndex(o => o.marketplaceOrderId === apiOrder.orderNumber);

      if (existingOrderIndex > -1) {
        const existingOrder = currentDbOrders[existingOrderIndex];

        // Don't update fully cancelled orders
        if (existingOrder.status === OrderStatus.CANCELLED && existingOrder.items.length === 0) {
          continue;
        }

        // UPDATE ITEM NAMES/DETAILS AND DETECT QUANTITY CHANGES FOR EXISTING ORDERS
        const apiItemMap = new Map();
        apiOrder.lines.forEach((line: any) => {
          apiItemMap.set(line.barcode || 'NO-BARCODE', line);
        });

        currentDbOrders[existingOrderIndex].items = existingOrder.items.map(item => {
          const apiLine = apiItemMap.get(item.barcode);
          if (apiLine) {
            // DETECT QUANTITY DECREASE (Partial Return for a single line)
            if (apiLine.quantity < item.quantity) {
              const diff = item.quantity - apiLine.quantity;
              console.log(`[DIFF-RETURN] Sipariş ${apiOrder.orderNumber}: ${item.barcode} barkodundan ${diff} adet iade algılandı. Stok iade ediliyor...`);

              const productIndex = currentDbProducts.findIndex(p => p.variants.some(v => v.barcode === item.barcode));
              if (productIndex > -1) {
                const product = currentDbProducts[productIndex];
                const variant = product.variants.find(v => v.barcode === item.barcode);
                if (variant) {
                  const whId = Object.keys(variant.stocks)[0] || 'wh1';
                  const currentStock = variant.stocks[whId] || 0;
                  const newStock = currentStock + diff;

                  const result = updateLocalStockWithConsistency(currentDbProducts, product.id, variant.color, variant.size, whId, newStock);
                  currentDbProducts = result.updatedProducts;

                  // Mark for sync
                  product.variants.forEach(pv => {
                    if (pv.barcode) barcodesToSync[pv.barcode] = Object.values(pv.stocks).reduce((a: any, b: any) => a + b, 0) as number;
                  });
                }
              }
            }

            return {
              ...item,
              productName: apiLine.productName || apiLine.name || item.productName,
              quantity: apiLine.quantity, // Update quantity to match API (reduced)
              totalPrice: (apiLine.price || item.unitPrice) * apiLine.quantity
            };
          }
          return item;
        });

        // PARTIAL CANCELLATION DETECTION AND STOCK RETURN
        const apiItemBarcodes = new Set(apiOrder.lines.map((line: any) => line.barcode || 'NO-BARCODE'));
        const cancelledItems = existingOrder.items.filter(item => !apiItemBarcodes.has(item.barcode));

        if (cancelledItems.length > 0) {
          console.log(`[PARTIAL-CANCEL] Sipariş ${apiOrder.orderNumber}: ${cancelledItems.length} ürün iptal edildi. Stoklar iade ediliyor...`);

          // RETURN STOCK FOR CANCELLED ITEMS
          cancelledItems.forEach(item => {
            const productIndex = currentDbProducts.findIndex(p => p.variants.some(v => v.barcode === item.barcode));
            if (productIndex > -1) {
              const product = currentDbProducts[productIndex];
              const variant = product.variants.find(v => v.barcode === item.barcode);
              if (variant) {
                const whId = Object.keys(variant.stocks)[0] || 'wh1';
                const currentStock = variant.stocks[whId] || 0;
                const newStock = currentStock + item.quantity;

                const result = updateLocalStockWithConsistency(
                  currentDbProducts,
                  product.id,
                  variant.color,
                  variant.size,
                  whId,
                  newStock
                );
                currentDbProducts = result.updatedProducts;

                // Sync new stock level
                if (db.settings.enableAutoStockSync) {
                  product.variants.forEach(pv => {
                    if (pv.barcode) {
                      const totalStock = Object.values(pv.stocks).reduce((a: any, b: any) => a + b, 0);
                      barcodesToSync[pv.barcode] = totalStock as number;
                    }
                  });
                }
              }
            }
          });

          const existingCancelledItems = existingOrder.cancelledItems || [];
          currentDbOrders[existingOrderIndex].cancelledItems = [...existingCancelledItems, ...cancelledItems];
          currentDbOrders[existingOrderIndex].items = currentDbOrders[existingOrderIndex].items.filter(item => apiItemBarcodes.has(item.barcode));

          if (currentDbOrders[existingOrderIndex].items.length === 0) {
            currentDbOrders[existingOrderIndex].status = OrderStatus.CANCELLED;
          }
        }

        // FULL CANCELLATION CHECK (Status change from active to cancelled)
        if (mappedStatus === OrderStatus.CANCELLED && existingOrder.status !== OrderStatus.CANCELLED) {
          console.log(`[FULL-CANCEL] Sipariş ${apiOrder.orderNumber}: Sipariş tamamen iptal edildi. Tüm stoklar iade ediliyor...`);
          existingOrder.items.forEach(item => {
            const productIndex = currentDbProducts.findIndex(p => p.variants.some(v => v.barcode === item.barcode));
            if (productIndex > -1) {
              const product = currentDbProducts[productIndex];
              const variant = product.variants.find(v => v.barcode === item.barcode);
              if (variant) {
                const whId = Object.keys(variant.stocks)[0] || 'wh1';
                const currentStock = variant.stocks[whId] || 0;
                const newStock = currentStock + item.quantity;

                const result = updateLocalStockWithConsistency(currentDbProducts, product.id, variant.color, variant.size, whId, newStock);
                currentDbProducts = result.updatedProducts;

                product.variants.forEach(pv => { if (pv.barcode) barcodesToSync[pv.barcode] = Object.values(pv.stocks).reduce((a: any, b: any) => a + b, 0) as number; });
              }
            }
          });

          const existingCancelledItems = existingOrder.cancelledItems || [];
          currentDbOrders[existingOrderIndex].cancelledItems = [...existingCancelledItems, ...existingOrder.items];
          currentDbOrders[existingOrderIndex].items = [];
          currentDbOrders[existingOrderIndex].status = OrderStatus.CANCELLED;
        }

        // Update cargo code if changed
        const newCargoCode = String(apiOrder.cargoTrackingNumber || apiOrder.trackingNumber || '-');
        if (existingOrder.cargoCode !== newCargoCode) {
          currentDbOrders[existingOrderIndex].cargoCode = newCargoCode;
        }

        // Update status if not suspended and NOT already handled by cancellation
        if (!existingOrder.isSuspended && existingOrder.status !== mappedStatus && existingOrder.status !== OrderStatus.CANCELLED) {
          currentDbOrders[existingOrderIndex].status = mappedStatus;
        }

        continue;
      }

      // Skip cancelled orders from being added as new
      if (mappedStatus === OrderStatus.CANCELLED) continue;

      if (mappedStatus !== OrderStatus.NEW && mappedStatus !== OrderStatus.PROCESSING) continue;

      let isSuspended = false;
      const orderItems: any[] = apiOrder.lines.map((line: any) => {
        // ALWAYS use Trendyol names
        const productName = line.productName || line.name || line.merchantSku || 'Ürün adı mevcut değil';

        // Get color from Trendyol first
        let color = line.attributes?.find((attr: any) => ['Renk', 'Color', 'RENK'].includes(attr.attributeName))?.attributeValue || line.color || '';

        // Only fallback to DB for color if empty, but NOT for productName
        if (!color && line.barcode && line.barcode !== 'NO-BARCODE') {
          const product = db.products.find(p => p.variants.some(v => v.barcode === line.barcode));
          if (product) {
            const variant = product.variants.find(v => v.barcode === line.barcode);
            if (variant) color = variant.color;
          }
        }

        return {
          orderItemId: String(line.orderItemId || line.id),
          barcode: line.barcode || 'NO-BARCODE',
          productName: productName,
          sku: line.merchantSku,
          color: color,
          size: line.attributes?.find((attr: any) => ['Beden', 'Size', 'BEDEN'].includes(attr.attributeName))?.attributeValue || line.size || '',
          quantity: line.quantity,
          unitPrice: line.price,
          totalPrice: line.price * line.quantity
        };
      });

      // Stock Reconcilliation
      let finalItems = orderItems.map(item => {
        const productIndex = currentDbProducts.findIndex(p => p.variants.some(v => v.barcode === item.barcode));

        if (productIndex > -1) {
          const product = currentDbProducts[productIndex];
          const variant = product.variants.find(v => v.barcode === item.barcode);

          if (variant) {
            // NEVER override productName here anymore
            if (db.settings.enableAutoStockSync) {
              const whId = Object.keys(variant.stocks)[0] || 'wh1';
              const currentStock = variant.stocks[whId] || 0;

              // STOK DÜŞÜM MANTIĞI: Miktar ne olursa olsun, eldeki stoktan düşer. 
              // Stok 0'ın altına inmez.
              let amountToSubtract = item.quantity;
              let newStock = Math.max(0, currentStock - amountToSubtract);

              const result = updateLocalStockWithConsistency(
                currentDbProducts,
                product.id,
                variant.color,
                variant.size,
                whId,
                newStock
              );

              currentDbProducts = result.updatedProducts;

              // Ürün kartındaki TÜM barkodları senkronizasyon listesine ekle
              product.variants.forEach(pv => {
                if (pv.barcode) {
                  const totalStock = Object.values(pv.stocks).reduce((a: any, b: any) => a + b, 0);
                  barcodesToSync[pv.barcode] = totalStock as number;
                }
              });
            }
          }
        } else {
          isSuspended = true;
        }
        return item;
      });

      let deliveryAddress = '';
      if (apiOrder.shipmentAddress) {
        deliveryAddress = [
          apiOrder.shipmentAddress.address1,
          apiOrder.shipmentAddress.address2,
          apiOrder.shipmentAddress.district,
          apiOrder.shipmentAddress.city,
          apiOrder.shipmentAddress.country
        ].filter(Boolean).join(', ');
      }

      const newOrder: Order = {
        id: Math.random().toString(36).substr(2, 9), // Simple ID generator for service
        marketplaceOrderId: apiOrder.orderNumber,
        storeName: config.storeName,
        status: mappedStatus,
        customerName: `${apiOrder.customerFirstName || ''} ${apiOrder.customerLastName || ''}`.trim(),
        deliveryAddress: deliveryAddress || undefined,
        cargoCode: String(apiOrder.cargoTrackingNumber || apiOrder.trackingNumber || '-'),
        orderDate: orderDate.toISOString(),
        items: finalItems,
        isSuspended: isSuspended,
        shipmentPackageId: apiOrder.id ? String(apiOrder.id) : undefined
      };

      // Auto Process Logic if enabled
      if (db.settings.enableAutoProcessOrders && !isSuspended && mappedStatus === OrderStatus.NEW) {
        newOrder.status = OrderStatus.PROCESSING;
        try {
          await syncOrderStatusToMarketplaces([config], [newOrder], OrderStatus.PROCESSING);
        } catch (error) {
          console.error('[AUTO-PROCESS-ERROR]', error);
        }
      }

      currentDbOrders.unshift(newOrder);
      newOrdersAddedCount++;
    }
  }

  return {
    updatedProducts: currentDbProducts,
    updatedOrders: currentDbOrders,
    newOrdersAddedCount,
    barcodesToSync
  };
};
